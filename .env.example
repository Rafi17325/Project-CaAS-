NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── Kamailio VoIP Server ──────────────────────────────────────────
NEXT_PUBLIC_SIP_SERVER=10.98.56.198
NEXT_PUBLIC_WEBSOCKET_URL=ws://10.98.56.198:8080

# SIP Auth: if Kamailio is configured to accept phone=password,
# leave this blank (the app will use the phone number as password).
# Otherwise set a domain-wide SIP password here:
NEXT_PUBLIC_SIP_DEFAULT_PASSWORD=123456
